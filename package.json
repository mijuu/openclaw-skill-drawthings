{
  "name": "@mijuu/drawthings",
  "version": "1.2.0",
  "description": "An AI-native CLI interface for Draw Things. It manages the official gRPC server and provides a professional local image generation bridge for AI agents on macOS.",
  "main": "scripts/generate.js",
  "bin": {
    "dt-skill": "./scripts/cli.js",
    "dt-mcp": "./scripts/mcp-server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mijuu/drawthings-agent.git"
  },
  "homepage": "https://github.com/mijuu/drawthings-agent#readme",
  "bugs": {
    "url": "https://github.com/mijuu/drawthings-agent/issues"
  },
  "scripts": {
    "dt": "node scripts/cli.js",
    "gen": "node scripts/cli.js gen",
    "config": "node scripts/cli.js config",
    "server:start": "node scripts/cli.js server start",
    "server:stop": "node scripts/cli.js server stop",
    "server:restart": "node scripts/cli.js server restart",
    "server:status": "node scripts/cli.js server status"
  },
  "keywords": [
    "drawthings",
    "ai",
    "image-generation",
    "grpc",
    "bridge",
    "cli",
    "macos",
    "agent-friendly",
    "local-ai"
  ],
  "files": [
    "scripts/",
    "references/",
    "README.md",
    "README_CN.md",
    "SKILL.md",
    "GEMINI.md",
    "LICENSE"
  ],
  "author": "raymond.liang@outlook.com",
  "license": "MIT",
  "dependencies": {
    "@grpc/grpc-js": "^1.12.6",
    "@grpc/proto-loader": "^0.7.13",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "commander": "^13.1.0",
    "flatbuffers": "^25.9.23",
    "pngjs": "^7.0.0"
  }
}
